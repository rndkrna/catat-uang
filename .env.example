# ========================================
# TULIS DUIT — Environment Variables
# Salin file ini menjadi .env lalu isi nilainya
# ========================================

# --- APP ---
# URL publik aplikasi (tanpa trailing slash)
# Contoh production: https://tulisduit.com
# Contoh lokal: http://localhost:3000
APP_URL=

# Supabase
SUPABASE_URL=
# Isi dengan service_role key (SECRET) dari Supabase dashboard
SUPABASE_KEY=

# --- META / WHATSAPP CLOUD API ---
# Dapatkan dari: https://developers.facebook.com/apps/
# > WhatsApp > API Setup

# Phone Number ID (bukan nomor WA-nya, tapi ID numerik dari Meta)
WHATSAPP_PHONE_NUMBER_ID=

# Access Token dari Meta App Dashboard
# (Temporary token untuk dev, permanent token untuEk production)
WHATSAPP_ACCESS_TOKEN=
# Harus sama persis dengan yang diisi di Meta Webhook Callback
WHATSAPP_VERIFY_TOKEN=

# --- AI (OPSIONAL) ---
# Untuk fitur scan struk / AI parser
GEMINI_API_KEY=

# Gemini AI Key untuk parser NLP
GEMINI_API_KEY=